{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "WriteMore",
  "version": "0.1.10",
  "identifier": "com.writemore.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "WriteMore",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhGOTM1RTc3NzY4NjE2OTkKUldTWkZvWjJkMTZUajYxTXJtN2NucjVhNkUrRWdiMXlYdWIwaWd3Z281cUYwTmVKWk5IdVE3dzQK",
      "endpoints": ["https://github.com/fivood/writemore/releases/latest/download/latest.json"],
      "dialog": false
    }
  }
}
